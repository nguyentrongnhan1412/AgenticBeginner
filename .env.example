# LangGraph Agentic App - Environment Variables
# Copy this file to .env and fill in your actual values

# Google AI API Key — get one at https://aistudio.google.com/
GOOGLE_API_KEY=your_google_api_key_here

# Gemini model names (optional — these are the defaults)
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Folder for drop-in PDFs (list/load by name via agent tools). Relative to app root or absolute.
# PDF_RESOURCE_DIR=resource

# Modal (for sandboxed command execution)
# Run: modal token new  — to authenticate interactively
# MODAL_TOKEN_ID and MODAL_TOKEN_SECRET are set automatically after modal token new
